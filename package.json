{
  "name": "playoffodds",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "IPL playoff probability tracker — Kalshi+Polymarket averaged, Monte Carlo over remaining schedule",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply playoffodds --local",
    "db:seed:local": "tsx scripts/seed-all.ts --local",
    "snapshot:dev": "tsx scripts/snapshot-dev.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src scripts",
    "lint:fix": "biome check --write src scripts",
    "format": "biome format --write src scripts"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "zod": "^3.23.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250515.0",
    "@biomejs/biome": "^1.9.0",
    "better-sqlite3": "^11.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.80.0"
  }
}
