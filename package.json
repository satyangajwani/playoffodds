{
  "name": "playoffodds",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "IPL playoff probability tracker — Kalshi+Polymarket averaged, Monte Carlo over remaining schedule",
  "scripts": {
    "dev": "tsx scripts/dev-server.ts",
    "dev:worker": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:seed": "tsx scripts/seed-all.ts",
    "db:reset": "rm -f dev.db && npm run db:seed",
    "snapshot:dev": "tsx scripts/snapshot-dev.ts",
    "build:css": "tsx scripts/build-css.ts",
    "prebuild:css": "echo regenerating styles.gen.ts from public/styles.css",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src scripts",
    "lint:fix": "biome check --write src scripts",
    "format": "biome format --write src scripts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.3",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "hono": "^4.6.0",
    "workers-og": "^0.0.27",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@cloudflare/workers-types": "^4.20250515.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.0",
    "better-sqlite3": "^11.3.0",
    "fast-check": "^4.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.80.0"
  }
}
